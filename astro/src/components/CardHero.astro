---
---
<div class="tactile-card hero-card" style="grid-column: span 8; grid-row: span 2;">
  <div class="tag">Flagship Project</div>
  <h2 class="card-title">Intelligent Energy Orchestration</h2>
  <p class="card-text">
    Leveraging the 35.2¢/kWh Ontario rate spread via AI-driven V2H (Vehicle-to-Home) systems.
  </p>
  
  <div class="hero-visual">
    <svg width="100%" height="200" viewBox="0 0 400 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- House -->
      <path d="M50 150H150V100L100 60L50 100V150Z" stroke="currentColor" stroke-width="2"/>
      <!-- Car -->
      <rect x="250" y="120" width="100" height="40" rx="4" stroke="currentColor" stroke-width="2"/>
      <circle cx="270" cy="165" r="8" stroke="currentColor" stroke-width="2"/>
      <circle cx="330" cy="165" r="8" stroke="currentColor" stroke-width="2"/>
      
      <!-- Power Line -->
      <path id="power-line" d="M150 125H250" stroke="var(--color-accent)" stroke-width="3" stroke-dasharray="10 5" />
      
      <!-- Flow Animation -->
      <circle r="4" fill="var(--color-accent)">
        <animateMotion dur="3s" repeatCount="indefinite" path="M150 125H250" />
      </circle>
    </svg>
  </div>
</div>

<style>
  .hero-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 450px;
    background: linear-gradient(135deg, var(--color-card-bg) 0%, rgba(76, 175, 80, 0.05) 100%);
  }
  
  .card-title {
    font-size: 3rem;
    max-width: 90%;
    font-family: var(--font-serif);
    margin-bottom: 1.5rem;
  }

  .card-text {
    font-size: 1.1rem;
    max-width: 80%;
  }
  
  .hero-visual {
    margin-top: 2rem;
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
    color: var(--color-text);
  }
  
  @media (max-width: 768px) {
    .hero-card {
      grid-column: span 1 !important;
      min-height: auto;
    }
    .card-title {
      font-size: 1.8rem;
    }
  }
</style>
