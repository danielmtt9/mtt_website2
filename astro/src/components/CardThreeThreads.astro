---
---
<div class="tactile-card venture-card" style="grid-column: span 4;">
  <div class="tag">Ventures</div>
  <h3 class="card-title">Three Threads</h3>
  <p class="card-text">
    A general apparel brand for everyone, powered by automated print-on-demand infrastructure.
  </p>
  <div class="card-action">
    <a href="https://threethreads.store" target="_blank" class="link-btn">Visit Store</a>
  </div>
</div>

<style>
  .card-action {
    margin-top: 2rem;
  }
  
  .link-btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-text);
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.8rem;
    transition: all 0.2s ease;
  }
  
  .link-btn:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
  }
  
  @media (max-width: 768px) {
    .venture-card {
      grid-column: span 1 !important;
    }
  }
</style>
