---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
import BentoGrid from '../components/BentoGrid.astro';
import CardHero from '../components/CardHero.astro';
import CardTechStack from '../components/CardTechStack.astro';
import CardThreeThreads from '../components/CardThreeThreads.astro';
import CardInvoice from '../components/CardInvoice.astro';
import CardVenture from '../components/CardVenture.astro';
import OntarioEdge from '../components/OntarioEdge.astro';
---

<Layout title="Maple Tyne Technologies | Tech Venture Studio">
	<main>
    <section class="hero-text">
      <h1 class="gradient-text">Engineering the <br/>Automated Future.</h1>
      <p class="sub-hero">Tech Venture Studio & Engineering Firm specializing in high-utility orchestration.</p>
    </section>
		
		<BentoGrid>
			<CardHero />
			<CardTechStack />
			<CardThreeThreads />
			<CardInvoice />
			<CardVenture />
		</BentoGrid>
		
		<OntarioEdge />
		
		<footer>
			<div class="footer-grid">
        <div class="footer-brand">
          <Logo size="small" />
          <p class="footer-desc">Building automated infrastructure for energy, apparel, and financial services.</p>
        </div>
				<div class="footer-details">
					<span class="location">Toronto, Ontario</span>
          <p class="copyright">&copy; 2026 Maple-Tyne Technologies Inc.</p>
				</div>
			</div>
		</footer>
	</main>
</Layout>

<style>
	main {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 4rem 0;
	}

  .hero-text {
    padding: 0 2rem 4rem;
  }

  .hero-text h1 {
    font-size: 4rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .sub-hero {
    font-size: 1.25rem;
    opacity: 0.7;
    max-width: 600px;
  }
	
	footer {
		margin-top: 8rem;
		border-top: 1px solid var(--color-border);
		padding: 4rem 2rem;
	}
	
	.footer-grid {
		display: grid;
    grid-template-columns: 2fr 1fr;
		gap: 2rem;
	}

  .footer-desc {
    margin-top: 1rem;
    opacity: 0.6;
    font-size: 0.9rem;
    max-width: 300px;
  }

  .footer-details {
    text-align: right;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .location {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-accent);
  }

  .copyright {
    margin-top: 0.5rem;
    opacity: 0.4;
    font-size: 0.75rem;
  }
	
	@media (max-width: 768px) {
    .hero-text h1 { font-size: 2.5rem; }
		.footer-grid {
			grid-template-columns: 1fr;
			text-align: center;
		}
    .footer-brand {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .footer-details {
      align-items: center;
    }
	}
</style>
